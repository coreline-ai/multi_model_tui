{
  "name": "multi-model-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx src/bin/dev.ts",
    "dev:proxy": "tsx src/bin/proxy.ts",
    "dev:tui": "tsx src/bin/tui.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/bin/dev.js",
    "start:proxy": "node dist/src/bin/proxy.js",
    "start:tui": "node dist/src/bin/tui.js",
    "test": "tsx --test test/*.test.ts test/unit/**/*.test.ts test/integration/**/*.test.ts test/smoke/**/*.test.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
